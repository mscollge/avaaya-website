<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INTREACT 2026</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,Helvetica,sans-serif}
body{background:#f5f8fc;color:#222}
html{scroll-behavior:smooth}

.header{
  background:#fff;
  padding:15px 7%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  box-shadow:0 2px 10px rgba(0,0,0,.08);
  position:sticky;
  top:0;
  z-index:999;
}

.logo-box{display:flex;align-items:center;gap:14px}
.logo-box img{width:70px;height:70px;object-fit:contain}
.logo-box h2{color:#063b82;font-size:22px}

nav a{
  color:#063b82;
  text-decoration:none;
  margin:0 8px;
  font-weight:bold;
  cursor:pointer;
}

nav a:hover{color:#e67e22}

.submit-btn{
  background:#e67e22;
  color:white!important;
  padding:10px 15px;
  border-radius:5px;
}

.page{
  display:none;
  padding:60px 8%;
  min-height:75vh;
}

.page.active{display:block}

.hero{
  background:linear-gradient(rgba(5,45,105,.88),rgba(5,45,105,.88));
  color:white;
  text-align:center;
  padding:90px 8%;
}

.hero h4{font-size:20px;margin-bottom:15px;color:#ffd36b}
.hero h1{font-size:48px;line-height:1.25;margin-bottom:15px}
.hero h2{font-size:30px;margin-bottom:18px}
.hero p{font-size:21px;margin-bottom:25px}

.btn{
  display:inline-block;
  background:#e67e22;
  color:white;
  text-decoration:none;
  padding:13px 25px;
  border-radius:5px;
  font-weight:bold;
  margin:8px;
  cursor:pointer;
}

.btn-blue{background:#0d6efd}

.info{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-top:35px;
}

.info-card{
  background:white;
  padding:25px;
  text-align:center;
  border-radius:10px;
  box-shadow:0 8px 25px rgba(0,0,0,.12);
}

.info-card h3{color:#063b82;margin-bottom:8px}
.info-card p{font-weight:bold}

.title{
  text-align:center;
  color:#063b82;
  font-size:34px;
  margin-bottom:30px;
}

.box{
  max-width:1000px;
  margin:auto;
  background:white;
  padding:35px;
  border-radius:10px;
  box-shadow:0 5px 18px rgba(0,0,0,.10);
  line-height:1.8;
  font-size:18px;
}

.box ul{list-style:none}
.box li{
  margin:12px 0;
  padding-left:28px;
  position:relative;
}

.box li:before{
  content:"✔";
  position:absolute;
  left:0;
  color:#e67e22;
  font-weight:bold;
}

.track-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
}

.track-card{
  background:white;
  padding:25px;
  border-radius:10px;
  box-shadow:0 4px 15px rgba(0,0,0,.08);
}

.track-card h3{color:#063b82;margin-bottom:15px}
.track-card ul{list-style:none}
.track-card li{
  margin:9px 0;
  padding-left:24px;
  position:relative;
}

.track-card li:before{
  content:"✓";
  position:absolute;
  left:0;
  color:#e67e22;
  font-weight:bold;
}

.date-table{
  max-width:850px;
  margin:auto;
  background:white;
  border-radius:10px;
  overflow:hidden;
  box-shadow:0 5px 18px rgba(0,0,0,.10);
}

.date-row{
  display:flex;
  justify-content:space-between;
  padding:18px 25px;
  border-bottom:1px solid #ddd;
  font-size:18px;
}

.date-row strong{color:#063b82}

footer{
  background:#022b5c;
  color:white;
  padding:30px 8%;
  text-align:center;
}

footer p{margin:5px 0}

@media(max-width:768px){
  .header{flex-direction:column;text-align:center}
  nav{margin-top:12px}
  nav a{display:inline-block;margin:6px}
  .hero h1{font-size:32px}
  .hero h2{font-size:23px}
  .date-row{flex-direction:column;gap:6px}
}
</style>
</head>

<body>

<div class="header">
